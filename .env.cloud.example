# Copy to .env.cloud on the VPS before running docker-compose.cloud.yml.
# Fill in ONE provider block below, then set CLOUDFLARE_TUNNEL_TOKEN.

# ── Option A: Anthropic Claude (recommended if you have an Anthropic API key) ─
# Hybrid cloud routing uses local Ollama on the VPS for cheaper draft work and
# keeps Claude available for higher-value review, grant, and fallback paths.
FOUNDERAI_PROVIDER=claude
FOUNDERAI_BASE_URL=https://api.anthropic.com/v1
FOUNDERAI_MODEL=claude-sonnet-4-6
FOUNDERAI_TIMEOUT_SECONDS=300
FOUNDERAI_API_KEY_ENV=ANTHROPIC_API_KEY
ANTHROPIC_API_KEY=
# ── Option B: OpenAI ──────────────────────────────────────────────────────────
# FOUNDERAI_PROVIDER=openai
# FOUNDERAI_BASE_URL=https://api.openai.com/v1
# FOUNDERAI_MODEL=gpt-5-mini
# FOUNDERAI_TIMEOUT_SECONDS=300
# FOUNDERAI_API_KEY_ENV=OPENAI_API_KEY
# OPENAI_API_KEY=

# ── Required: Cloudflare Tunnel token ─────────────────────────────────────────
# Create a tunnel at https://one.dash.cloudflare.com → Networks → Tunnels
# Copy the token from the tunnel install command.
CLOUDFLARE_TUNNEL_TOKEN=

# ── Optional ops helpers ──────────────────────────────────────────────────────
FOUNDERAI_CLOUD_ROOT=/srv/founderai
FOUNDERAI_BACKUP_REMOTE=
