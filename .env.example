# Copy this file to .env or .env.local for local use.
# Real secrets stay only in the untracked local file.

# Claude-first local setup
FOUNDERAI_PROVIDER=claude
FOUNDERAI_BASE_URL=https://api.anthropic.com/v1
FOUNDERAI_MODEL=claude-sonnet-4-6
FOUNDERAI_TIMEOUT_SECONDS=600
FOUNDERAI_SYSTEM_PROMPT=You are FounderAI's autonomous provider worker. Follow the prompt packet exactly and write only the requested final deliverable.
FOUNDERAI_API_KEY_ENV=ANTHROPIC_API_KEY
ANTHROPIC_API_KEY=

# Optional local Ollama fallback if you want to switch back temporarily:
# FOUNDERAI_PROVIDER=ollama
# FOUNDERAI_BASE_URL=http://localhost:11434
# FOUNDERAI_MODEL=qwen2.5:3b-instruct
