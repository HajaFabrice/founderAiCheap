{
  "workspace_root": "..",
  "founder_brain_path": "../founder-brain",
  "runtime_dir": "../runtime-smoke",
  "inbox_dir": "../inbox-smoke",
  "outbox_dir": "../outbox-smoke",
  "agents_path": "agents.json",
  "deadlines_path": "pio_deadlines.json",
  "poll_interval_seconds": 60,
  "internet_check": {
    "enabled": true,
    "hosts": [
      {
        "host": "1.1.1.1",
        "port": 53
      },
      {
        "host": "8.8.8.8",
        "port": 53
      }
    ],
    "timeout_seconds": 2.0
  },
  "worker": {
    "provider": "ollama",
    "base_url": "http://localhost:11434",
    "model": "qwen2.5:7b-instruct",
    "timeout_seconds": 1800,
    "system_prompt": "You are FounderAI's autonomous provider worker. Follow the prompt packet exactly and write only the requested final deliverable.",
    "api_key_env": "OPENAI_API_KEY"
  },
  "strategic_validation": {
    "always_require_tags": [
      "external-send",
      "publish",
      "financial",
      "destructive-write",
      "calendar-commitment"
    ],
    "default_policy": "after_run"
  },
  "inbox_request_defaults": {
    "approval_policy": "inherit",
    "requires_internet": false,
    "risk_tags": []
  },
  "model_router": {
    "task_types": {
      "draft": {
        "prefer": "offline",
        "fallback": "online"
      },
      "qa_check": {
        "prefer": "offline",
        "fallback": "offline"
      },
      "briefing": {
        "prefer": "offline",
        "fallback": "offline"
      },
      "final_review": {
        "prefer": "online",
        "fallback": "offline"
      },
      "proposal": {
        "prefer": "online",
        "fallback": "offline"
      },
      "phd_analysis": {
        "prefer": "online",
        "fallback": "offline"
      },
      "grant": {
        "prefer": "online",
        "fallback": "offline"
      },
      "scheduler": {
        "prefer": "offline",
        "fallback": "offline"
      }
    },
    "connectivity_check_url": "https://1.1.1.1",
    "connectivity_timeout_seconds": 5
  },
  "offline_queue": {
    "enabled": true,
    "path": "runtime/offline_queue/",
    "replay_on_job": "internet-recovery-review"
  },
  "notifier": {
    "enabled": false,
    "slack_webhook_env": "FOUNDERAI_SLACK_WEBHOOK_URL"
  },
  "team_roles": [
    {
      "id": "A-Outreach",
      "team": "A",
      "role": "Outreach",
      "display_name": "Outreach Specialist A",
      "saint_name": "Anthony",
      "agent_id": "anthony",
      "daily_quota": 5,
      "metric_unit": "prospects",
      "focus": "Cash-flow outreach for biodiversity data cleaning and validation support.",
      "responsibilities": [
        "Research NGOs and field programs needing data cleaning support",
        "Qualify prospects and log core context",
        "Draft first-touch outreach and follow-up assets",
        "Queue anything external for approval"
      ],
      "default_risk_tags": [
        "external-send"
      ],
      "default_approval_policy": "inherit"
    },
    {
      "id": "A-Production",
      "team": "A",
      "role": "Production",
      "display_name": "Production Specialist A",
      "saint_name": "Juniper",
      "agent_id": "juniper",
      "daily_quota": 1,
      "metric_unit": "delivery-packet",
      "focus": "Client delivery, data cleaning execution, portfolio samples, and reusable templates.",
      "responsibilities": [
        "Draft delivery schedules and QC workflows",
        "Clean datasets and prepare summary sheets",
        "Build reusable templates when no live client exists"
      ],
      "default_risk_tags": [],
      "default_approval_policy": "inherit"
    },
    {
      "id": "B-Outreach",
      "team": "B",
      "role": "Outreach",
      "display_name": "Outreach Specialist B",
      "saint_name": "Bonaventure",
      "agent_id": "bonaventure",
      "daily_quota": 3,
      "metric_unit": "prospects",
      "focus": "Growth-engine outreach for MRV, biodiversity consulting, and institutional partnerships.",
      "responsibilities": [
        "Identify REDD+, donor, NGO, and institutional leads",
        "Qualify prospects and log context",
        "Draft partnership-style outreach and follow-ups",
        "Hand opportunities to Production Specialist B"
      ],
      "default_risk_tags": [
        "external-send"
      ],
      "default_approval_policy": "inherit"
    },
    {
      "id": "B-Production",
      "team": "B",
      "role": "Production",
      "display_name": "Production Specialist B",
      "saint_name": "Bernardine",
      "agent_id": "bernardine",
      "daily_quota": 1,
      "metric_unit": "proposal-asset",
      "focus": "MRV methodologies, proposals, budgets, and consulting assets.",
      "responsibilities": [
        "Draft methodology sections and consulting assets",
        "Prepare sample deliverables and budgets",
        "Build SOPs, whitepapers, and MRV pipeline collateral"
      ],
      "default_risk_tags": [],
      "default_approval_policy": "inherit"
    },
    {
      "id": "C-Outreach",
      "team": "C",
      "role": "Outreach",
      "display_name": "Outreach Specialist C",
      "saint_name": "Jacinta",
      "agent_id": "jacinta",
      "daily_quota": 2,
      "metric_unit": "prospects",
      "focus": "Supervisor, grant, and institutional partner outreach for the PhD and research engine.",
      "responsibilities": [
        "Find supervisors, grants, and institutional contacts",
        "Qualify outreach targets",
        "Draft first-touch and follow-up messages",
        "Log opportunities for Production Specialist C"
      ],
      "default_risk_tags": [
        "external-send"
      ],
      "default_approval_policy": "inherit"
    },
    {
      "id": "C-Production",
      "team": "C",
      "role": "Production",
      "display_name": "Production Specialist C",
      "saint_name": "Duns Scotus",
      "agent_id": "duns-scotus",
      "daily_quota": 5,
      "metric_unit": "papers",
      "focus": "Literature review, PhD proposal sections, grants, budgets, manuscripts, and research methods.",
      "responsibilities": [
        "Read papers and update literature notes",
        "Draft proposal sections, manuscript outlines, and methods",
        "Prepare grant materials, budgets, and fieldwork plans"
      ],
      "default_risk_tags": [],
      "default_approval_policy": "inherit"
    }
  ],
  "jobs": []
}
